# ─── PostgreSQL ───────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=bi_chat
PG_USER=bi_user
PG_PASSWORD=bi_password

# ─── Keycloak ─────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=bi-chat
KEYCLOAK_CLIENT_ID=bi-chat-app
KEYCLOAK_CLIENT_SECRET=your_client_secret_here

# ─── Ollama ───────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── Application ──────────────────────────────────────────────
APP_MAX_ROWS=500
APP_CACHE_SIMILARITY_THRESHOLD=0.92
APP_SQL_TIMEOUT_SECONDS=20
